# Copy to .env and fill in your values:
#   cp .env.example .env
OKP_ACCESS_KEY=your-access-key-here

# Functional tests (uv run pytest -m functional)
# Copy this file to .env in the repo root. Paths can be absolute or ~/… (tilde expanded).
# GOOGLE_CLOUD_PROJECT must match a project where this SA can call Vertex AI (Gemini).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional Vertex model for functional tests (default: gemini-2.5-flash).
# If you see vertexai.allowedModels / "disallowed Gen AI model gemini-2.5-flash", set a model
# your org allows (ask admin or see GCP console Organization Policy). Examples to try:
# OKP_FUNCTIONAL_MODEL=gemini-2.0-flash-001
# OKP_FUNCTIONAL_MODEL=gemini-1.5-flash
