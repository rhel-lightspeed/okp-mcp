# Google Cloud / Vertex AI Configuration
# Replace with your actual GCP project ID
VERTEX_AI_PROJECT=your-gcp-project-id

# Google Cloud region for Vertex AI services
# Common values: us-central1, us-east1, europe-west1
VERTEX_AI_LOCATION=us-central1

# Path to GCP service account JSON credentials file on the HOST machine
# This file should contain your Google Cloud service account key
# Example: /home/username/.config/gcloud/application_default_credentials.json
GCP_CREDENTIALS_PATH=/path/to/google-credentials.json

# Path to GCP credentials INSIDE the container (used by Vertex AI SDK)
# Do not change this unless you modify the volume mount in podman-compose.yaml
GOOGLE_APPLICATION_CREDENTIALS=/opt/app-root/.gcp-keys/credentials.json
