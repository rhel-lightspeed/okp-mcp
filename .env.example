# Copy to .env and fill in your values:
#   cp .env.example .env
OKP_ACCESS_KEY=your-access-key-here

# Pinned documents for development/testing (search_documentation only)
# Comma-separated Solr document IDs to pin at top of search results
# Example: MCP_PIN_SEARCH_DOCS=/documentation/en-us/red_hat_enterprise_linux/9/html-single/configuring_and_using_database_servers/index
# Optional query suffix for pinned documents (appended to search query when fetching pinned docs)
# MCP_PIN_SEARCH_QUERY_SUFFIX=additional terms
