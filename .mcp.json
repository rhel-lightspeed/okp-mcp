{
    "mcpServers": {
        "okp-mcp": {
            "command": "uv",
            "args": [
                "run",
                "fastmcp",
                "run",
                "src/okp_mcp/__init__.py:mcp",
                "--transport",
                "stdio",
                "--reload",
                "--reload-dir",
                "src/"
            ]
        }
    }
}
